{
  "name": "cartpole",
  "recordType": "cartpole-run",
  "run": ".venv/bin/python -m trainer.run --config-json {configPath} --summary-out {summaryOut}",
  "calibrate": ".venv/bin/python -m trainer.run --calibrate --summary-out {summaryOut}",
  "objective": { "name": "eval_return_mean", "direction": "max" },
  "levers": {
    "algo": { "type": "choice", "choices": ["ppo", "dqn"], "default": "ppo" },
    "learning_rate": { "type": "number", "default": 0.0003, "range": [0.00001, 0.01] },
    "gamma": { "type": "number", "default": 0.99, "range": [0.8, 0.9999] },
    "total_timesteps": { "type": "number", "default": 8000, "range": [1000, 200000] },
    "net_arch": { "type": "choice", "choices": ["64,64", "256,256"], "default": "64,64" },
    "seed": { "type": "number", "default": 0 }
  },
  "eta": { "unitsLever": "total_timesteps" },
  "data": [],
  "resources": { "gpu": false, "memory": "2g", "cpus": 2 }
}
